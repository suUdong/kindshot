# === Anthropic (paper 모드에서 필요) ===
ANTHROPIC_API_KEY=sk-ant-...

# === KIS 한국투자증권 API ===
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
KIS_IS_PAPER=true

# === Feed ===
FEED_SOURCE=KIS  # KIS (AWS호환) 또는 KIND (로컬용)

# === 옵션 ===
LOG_DIR=/opt/kindshot/logs
LLM_MODEL=claude-haiku-4-5-20251001
ADV_THRESHOLD=5000000000
FEED_INTERVAL_MARKET=3.0
