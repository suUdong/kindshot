# ━━━ kindshot micro-live 전용 .env 설정 ━━━
#
# paper 모드 .env에서 아래 항목만 변경/추가하면 됩니다.
# 나머지 설정은 기존 .env 그대로 유지.

# === 핵심 변경 ===

# 실전 서버 사용 (paper=모의투자 서버)
KIS_IS_PAPER=false

# 실계좌 API 키 (모의투자 키와 다름!)
KIS_APP_KEY=실전용_앱키
KIS_APP_SECRET=실전용_시크릿
KIS_ACCOUNT_NO=1234567801

# === 안전장치 ===

# 1건당 주문 금액 상한 (원). 기본 100만원.
# 시그널의 ORDER_SIZE가 500만원이어도 이 값으로 캡핑됨.
MICRO_LIVE_MAX_ORDER_WON=1000000

# 포지션 수 제한 (micro-live는 1~2개 권장)
MAX_POSITIONS=2

# 주문 크기 축소 (micro-live 기본)
ORDER_SIZE=1000000
ORDER_SIZE_L=1500000
ORDER_SIZE_S=500000

# 일일 손실 한도 축소
DAILY_LOSS_LIMIT=500000

# === 선택 변경 ===

# 연패 중단 (2연패 시 사이즈 다운, 3연패 시 당일 중단)
CONSECUTIVE_LOSS_SIZE_DOWN=2
CONSECUTIVE_LOSS_HALT=3
