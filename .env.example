# === Anthropic (paper 모드에서 필요) ===
ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=claude-haiku-4-5-20251001
# LLM_MAX_CONCURRENCY=2

# === KIS 한국투자증권 API (optional — 없으면 가격 조회 비활성) ===
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
KIS_IS_PAPER=true

# === Feed ===
# FEED_SOURCE=KIS          # KIS (AWS compatible) or KIND (local, KRX access 필요)
# FEED_INTERVAL_MARKET=3.0 # 장중 폴링 간격 (초)
# FEED_INTERVAL_OFF=15.0   # 장외 폴링 간격 (초)
# FEED_OVERLAP_S=90

# === Quant 필터 ===
# ADV_THRESHOLD=500000000       # 20일 평균 거래대금 최소 (원)
# SPREAD_CHECK_ENABLED=true
# SPREAD_MISSING_POLICY=pass    # pass=fail-open, fail=fail-close
# CHASE_BUY_PCT=3.0             # 당일 상승률 이상이면 BUY 차단
# MIN_BUY_CONFIDENCE=72         # BUY 최소 confidence

# === 매매 타이밍 ===
# NO_BUY_AFTER_KST_HOUR=15     # 15:00 이후 BUY 차단
# NO_BUY_AFTER_KST_MINUTE=0

# === Paper Trading TP/SL ===
# PAPER_TAKE_PROFIT_PCT=1.5
# PAPER_STOP_LOSS_PCT=-1.0

# === Trailing Stop ===
# TRAILING_STOP_ENABLED=true
# TRAILING_STOP_PCT=0.8           # peak 대비 하락폭 (%)
# TRAILING_STOP_ACTIVATION_PCT=0.8 # 활성화 최소 수익률 (%)
# MAX_HOLD_MINUTES=30             # 최대 보유 시간 (0=비활성)

# === 포트폴리오 리스크 ===
# DAILY_LOSS_LIMIT=3000000  # 일일 손실 한도 (원)
# MAX_POSITIONS=5
# MAX_SECTOR_POSITIONS=2
# ORDER_SIZE=5000000        # 기본 주문 크기 (원, M size)
# ORDER_SIZE_L=7000000      # L size (high confidence)
# ORDER_SIZE_S=3000000      # S size (low confidence)

# === Market ===
# KOSPI_HALT_PCT=-8.0
# MIN_MARKET_BREADTH_RATIO=0.3

# === Health 서버 ===
# HEALTH_HOST=127.0.0.1  # Docker에서는 0.0.0.0
# HEALTH_PORT=8080

# === UNKNOWN 리뷰 ===
# UNKNOWN_SHADOW_REVIEW_ENABLED=true
# UNKNOWN_PAPER_PROMOTION_ENABLED=true
# UNKNOWN_PROMOTION_MIN_CONFIDENCE=85

# === Pipeline ===
# PIPELINE_WORKERS=4
# PIPELINE_QUEUE_MAXSIZE=512

# === 캐시 ===
# PYKRX_CACHE_TTL_S=300
# PYKRX_CACHE_MAX_SIZE=512

# === 경로 ===
# LOG_DIR=logs
# DATA_DIR=data
