# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# KIS (optional - price fetching disabled if missing)
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
KIS_IS_PAPER=true

# Feed source: KIS (AWS compatible) or KIND (local, requires KRX access)
# FEED_SOURCE=KIS

# Overrides
# ADV_THRESHOLD=5000000000
# SPREAD_CHECK_ENABLED=false
# LOG_DIR=logs
# PIPELINE_WORKERS=4
# PIPELINE_QUEUE_MAXSIZE=512
# PYKRX_CACHE_TTL_S=300
# PYKRX_CACHE_MAX_SIZE=512
# LLM_MAX_CONCURRENCY=2
